# ═══════════ SUPABASE ═══════════
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ═══════════ STRIPE ═══════════
STRIPE_SECRET_KEY=sk_test_your_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Price IDs (from your Stripe dashboard → Products)
STRIPE_PRO_MONTHLY_PRICE_ID=price_xxx
STRIPE_PRO_YEARLY_PRICE_ID=price_xxx
STRIPE_ULTIMATE_MONTHLY_PRICE_ID=price_xxx
STRIPE_ULTIMATE_YEARLY_PRICE_ID=price_xxx
STRIPE_ULTIMATE_LIFETIME_PRICE_ID=price_xxx

# ═══════════ RESEND (Email) ═══════════
RESEND_API_KEY=re_your_key_here
EMAIL_FROM=alerts@yourdomain.com

# ═══════════ TELEGRAM ═══════════
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ═══════════ CRON ═══════════
CRON_SECRET=make_up_a_random_string_here

# ═══════════ APP ═══════════
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
